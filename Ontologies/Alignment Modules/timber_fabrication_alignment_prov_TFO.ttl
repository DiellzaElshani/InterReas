@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tfo: <https://w3id.org/timber-fabrication-ontology#> .

tfo:Agent rdfs:subClassOf prov:Agent .

tfo:FabricationElement rdfs:subClassOf prov:Entity .

tfo:FabricationProcess rdfs:subClassOf prov:Activity .

tfo:FabricationTask rdfs:subClassOf prov:Activity .

tfo:ProcessPhase rdfs:subClassOf prov:Activity .

tfo:performedBy rdfs:subPropertyOf prov:wasAssociatedWith .

tfo:precedesTask skos:closeMatch prov:wasInformedBy .

tfo:producesElement rdfs:subPropertyOf prov:generated .

tfo:usesInputElement rdfs:subPropertyOf prov:used .

<https://w3id.org/timber-fabrication-ontology/alignment/prov> a owl:Ontology ;
    dcterms:title "Timber Fabrication Ontology Alignment Module - PROV-O"@en ;
    rdfs:comment "Alignment module between the Timber Fabrication Ontology and PROV-O for provenance of fabrication tasks, agents, and entities."@en ;
    owl:imports <http://www.w3.org/ns/prov-o>,
        <https://w3id.org/timber-fabrication-ontology> .

